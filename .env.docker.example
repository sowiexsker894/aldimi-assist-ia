# Plantilla de variables para Docker Compose (referencia).
# Los valores por defecto ya están en docker-compose.yml.
# Para overrides: copia a .env.docker y usa:
#   docker compose --env-file .env.docker up --build
#
# No subir .env.docker al repositorio.

# --- PostgreSQL (servicio postgres) ---
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=aldimi_core

# --- service-core ---
# DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/aldimi_core
# VISION_SERVICE_URL=http://service-vision:8000
# NLP_SERVICE_URL=http://service-nlp:8000
# CORS_ORIGINS=http://localhost:4200
# JWT_SECRET=dev-docker-secret-minimum-32-characters-long

# --- service-nlp / service-vision (stub por defecto) ---
# LLM_PROVIDER=stub
# GATEKEEPER_PROVIDER=stub

