# Copiar a .env y ajustar
PROJECT_NAME="ALDIMI service-nlp"
CORS_ORIGINS=http://localhost:4200

# Base URL de service-core (sin barra final). Opcional hasta integrar llamadas HTTP.
# Ejemplo: http://127.0.0.1:8000
SERVICE_CORE_BASE_URL=

# Chat: stub local o Azure (endpoint /openai/v1 del portal)
LLM_PROVIDER=stub

# Con LLM_PROVIDER=azure (ejemplo; usar tu recurso y despliegue)
# OPENAI_BASE_URL=https://<recurso>.openai.azure.com/openai/v1
# OPENAI_API_KEY=<api-key>
# OPENAI_CHAT_MODEL=gpt-4.1

# Opcional: sustituir la instrucción de sistema por defecto (app/core/aldimi_system_prompt.py)
# CHAT_SYSTEM_PROMPT=

# Arranque paralelo a service-core (misma máquina):
#   uvicorn app.main:app --reload --port 8001
