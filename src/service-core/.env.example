# Copia a .env y ajusta (no subir .env al repositorio)

# PostgreSQL (SQLAlchemy sync + psycopg v3)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/aldimi_core

# Microservicios IA (opcionales hasta integración real)
NLP_SERVICE_URL=
VISION_SERVICE_URL=http://127.0.0.1:8002

# API
PROJECT_NAME=ALDIMI service-core
CORS_ORIGINS=http://localhost:4200

# JWT (misma clave en todos los entornos dev; producción: secreto fuerte)
JWT_SECRET=change-me-in-production

# Tras migración 002: usuario semilla admin@aldimi.local / AdminDev123!
