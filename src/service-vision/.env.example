# Copiar a .env y ajustar
PROJECT_NAME="ALDIMI service-vision"
CORS_ORIGINS=http://localhost:4200

SERVICE_CORE_BASE_URL=

# stub (local) | azure
LLM_PROVIDER=stub

# stub (modelo clasificador en entrenamiento; futuro: ml)
GATEKEEPER_PROVIDER=stub

# Azure (mismo patrón /openai/v1 que service-nlp)
# OPENAI_BASE_URL=https://<recurso>.openai.azure.com/openai/v1
# OPENAI_API_KEY=<api-key>
# OPENAI_VISION_MODEL=gpt-4.1

# Límites multi-imagen (opcional; valores por defecto razonables)
# MAX_VISION_INPUT_IMAGES=8
# MAX_IMAGE_BASE64_CHARS_PER_IMAGE=4000000
# MAX_TOTAL_JPEG_BYTES_AFTER_PREPROCESS=20971520

# Preprocesado OpenCV
# PREPROCESS_JPEG_QUALITY=90
# PREPROCESS_MAX_WIDTH=2000

# Opcional: sustituir prompt de extractor DNI
# DNI_SYSTEM_PROMPT=
# RECETA_SYSTEM_PROMPT=
# RECIBO_SYSTEM_PROMPT=

# Ejemplo (puerto libre; ajustar si choca):
#   uvicorn app.main:app --reload --port 8002
